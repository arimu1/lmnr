# FULL LOCAL ENV (worktree-01)
DATABASE_URL="postgres://postgres:postgres_passwordabc@localhost:5433/postgres"

PORT=8010
GRPC_PORT=8011
CONSUMER_PORT=8012

CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=ch_user
CLICKHOUSE_PASSWORD=ch_passwd
CLICKHOUSE_RO_USER=ch_user
CLICKHOUSE_RO_PASSWORD=ch_passwd

SHARED_SECRET_TOKEN=some_secret
# must be exactly 32 bytes (64 hex characters)
AEAD_SECRET_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
ENVIRONMENT=LITE

QUERY_ENGINE_URL=http://localhost:8913

QUICKWIT_INGEST_URL=http://localhost:7281
QUICKWIT_SEARCH_URL=http://localhost:7280
QUICKWIT_SPANS_INDEX_ID=spans_v2

# OAuth JWKS - explicit override for the worktree-01 frontend port
FRONTEND_URL=http://localhost:3010
NEXT_INTERNAL_URL=http://localhost:3010

